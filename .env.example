# Pipeline Agent — Environment Configuration
# Copy to .env and fill in your values.
# Only set what you need — everything has a sensible default.

# ─── PostgreSQL (main store + pgvector) ──────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=pipeline_agent
PG_USER=pipeline_agent
PG_PASSWORD=pipeline_agent
PG_POOL_MIN=2
PG_POOL_MAX=10

# ─── Agent (Claude API) ─────────────────────────────────────────────────────
# Required for AI reasoning and connector generation.
# Without this, the agent uses rule-based fallback and cannot generate connectors.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# ─── Embeddings (optional) ──────────────────────────────────────────────────
# Enables semantic preference search via pgvector.
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3

# ─── Staging ─────────────────────────────────────────────────────────────────
DATA_DIR=./data
MAX_DISK_PCT=85
BATCH_SIZE=50000

# ─── Scheduler ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_PIPELINES=4

# ─── Alerts (all optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
PAGERDUTY_ROUTING_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8100
LOG_LEVEL=INFO

# ─── Auth ────────────────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true for production deployments.
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── Encryption ──────────────────────────────────────────────────────────────
# Fernet key for encrypting credentials at rest in PostgreSQL.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
